{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/cariera/layout,_N_T_/cariera/[slug]/layout,_N_T_/cariera/[slug]/page,_N_T_/cariera/ambulantier"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/cariera/$d$slug/__PAGE__",
    "/cariera/$d$slug",
    "/cariera",
    "/_index",
    "/_head"
  ]
}